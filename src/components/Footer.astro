---
import { useTranslations, routes, type Lang, CONTACT } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const altLang = lang === "es" ? "en" : "es";
---

<footer class="ftr">
  <div class="wrap wrap--wide ftr__grid">
    <div class="ftr__brand">
      <a class="ftr__logo" href={r.home}>ArtiMind<span>Art</span></a>
      <p class="ftr__tag">{t("footer.tagline")}</p>
      <a class="ftr__mail" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
    </div>

    <nav class="ftr__col">
      <h3>{t("footer.nav")}</h3>
      <a href={r.services}>{t("nav.services")}</a>
      <a href={r.work}>{t("nav.work")}</a>
      <a href={r.blog}>{t("nav.blog")}</a>
      <a href={r.about}>{t("nav.bio")}</a>
      <a href={r.contact}>{t("nav.contact")}</a>
    </nav>

    <nav class="ftr__col">
      <h3>{t("footer.social")}</h3>
      <a href={CONTACT.x} target="_blank" rel="noopener">X / Twitter</a>
      <a href={CONTACT.magnific} target="_blank" rel="noopener">Magnific</a>
      <a href={routes[altLang].home}>{altLang.toUpperCase()}</a>
    </nav>

    <div class="ftr__cta">
      <p class="ftr__cta-h">{t("footer.cta")}</p>
      <a class="btn btn--on-dark" href={r.contact}>{t("nav.cta")} <span class="arrow">→</span></a>
    </div>
  </div>

  <div class="wrap wrap--wide ftr__bottom">
    <span>© {new Date().getFullYear()} ArtiMindArt — {t("footer.rights")}</span>
    <span class="ftr__partner">Magnific Partner</span>
  </div>
</footer>

<style>
  .ftr { background: var(--ink); color: #fff; padding: clamp(3.5rem, 6vw, 5.5rem) 0 2rem; }
  .ftr__grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 2rem; padding-bottom: clamp(2.5rem,5vw,4rem); border-bottom: 1px solid rgba(255,255,255,.16); }
  .ftr__logo { font-family: var(--font-display); font-size: 1.5rem; }
  .ftr__logo span { font-style: italic; }
  .ftr__tag { color: rgba(255,255,255,.6); margin: 1.1rem 0 0.9rem; max-width: 32ch; font-size: 0.92rem; }
  .ftr__mail { color: #fff; border-bottom: 1px solid rgba(255,255,255,.35); padding-bottom: 2px; }
  .ftr__col { display: grid; gap: 0.75rem; align-content: start; }
  .ftr__col h3 { font-family: var(--font); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2em; color: rgba(255,255,255,.45); font-weight: 500; margin-bottom: 0.4rem; }
  .ftr__col a { color: rgba(255,255,255,.78); font-size: 0.95rem; transition: color 0.25s; width: fit-content; }
  .ftr__col a:hover { color: #fff; }
  .ftr__cta-h { font-family: var(--font-display); font-size: 1.3rem; margin: 0 0 1.2rem; }
  .ftr__bottom { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; font-size: 0.74rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,.5); }
  @media (max-width: 820px) { .ftr__grid { grid-template-columns: 1fr 1fr; } }
</style>
