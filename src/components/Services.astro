---
import { useTranslations, routes, type Lang } from "../i18n/ui";
import { services } from "../data/services";
interface Props { lang: Lang; linkToDetail?: boolean }
const { lang, linkToDetail = false } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const covers = ["/img/rooftop.jpg", "/img/sunglasses.jpg", "/img/carwash.jpg"];
const blocks = services[lang].map((s, i) => ({
  title: s.title,
  body: s.intro,
  img: covers[i],
  n: String(i + 1).padStart(2, "0"),
  href: `${r.services}${s.slug}/`,
}));
---

<section class="svcs section" id="services">
  <div class="wrap svcs__list">
    {blocks.map((b, i) => (
      <article class={`svc ${i % 2 ? "svc--flip" : ""}`} data-reveal>
        <div class="svc__media"><img src={b.img} alt={b.title} loading="lazy" /></div>
        <div class="svc__text">
          <span class="svc__n">{b.n} / 03</span>
          <h3 class="h-md svc__name">{b.title}</h3>
          <p>{b.body}</p>
          {linkToDetail && (
            <a class="tlink svc__link" href={b.href}>{t("svc.more")} <span class="arrow">→</span></a>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .svcs { background: var(--bg); }
  .svcs__list { display: grid; gap: clamp(3rem, 6vw, 6rem); }
  .svc { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 5vw, 5rem); align-items: center; }
  .svc--flip .svc__media { order: 2; }
  .svc__media { overflow: hidden; aspect-ratio: 5/4; border: 1px solid var(--line); filter: grayscale(1); transition: filter 0.7s var(--ease); }
  .svc:hover .svc__media { filter: grayscale(0); }
  .svc__media img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.1s var(--ease); }
  .svc:hover .svc__media img { transform: scale(1.03); }
  .svc__n { display: block; font-size: 0.74rem; letter-spacing: 0.2em; color: var(--muted); margin-bottom: 1.2rem; }
  .svc__name { margin-bottom: 1.1rem; }
  .svc__text p { color: var(--muted); max-width: 46ch; margin: 0; }
  .svc__link { margin-top: 1.6rem; }
  @media (max-width: 820px) {
    .svc { grid-template-columns: 1fr; gap: 1.5rem; }
    .svc--flip .svc__media { order: 0; }
    .svc__media { aspect-ratio: 4/3; }
  }
</style>
