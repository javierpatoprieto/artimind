---
import { useTranslations, routes, type Lang, type PageKey, CONTACT } from "../i18n/ui";
interface Props { lang: Lang; page: PageKey | "legal"; altHref: string; dark?: boolean }
const { lang, page, altHref, dark = false } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const altLang = lang === "es" ? "en" : "es";

const nav: { key: PageKey; label: string; n: string; img: string }[] = [
  { key: "services", label: t("nav.services"), n: "01", img: "/img/rooftop.webp" },
  { key: "work", label: t("nav.work"), n: "02", img: "/img/sunglasses.webp" },
  { key: "blog", label: t("nav.blog"), n: "03", img: "/img/laundry.webp" },
  { key: "about", label: t("nav.bio"), n: "04", img: "/img/javier-foto.webp" },
  { key: "contact", label: t("nav.contact"), n: "05", img: "/img/carwash.webp" },
];
---

<header class={`hdr ${dark ? "is-dark" : ""}`} id="site-header" data-dark={dark ? "1" : "0"}>
  <div class="hdr__inner wrap wrap--wide">
    <a class="hdr__logo" href={r.home} aria-label="ArtiMindArt">ArtiMind<span>Art</span></a>
    <div class="hdr__right">
      <a class="hdr__lang" href={altHref} aria-label={`Switch to ${altLang}`}>{altLang.toUpperCase()}</a>
      <button class="hdr__menu" id="menu-open" aria-controls="fullmenu" aria-expanded="false">
        <span class="hdr__menu-label">{t("menu.title")}</span>
        <span class="hdr__burger" aria-hidden="true"><span></span><span></span></span>
      </button>
    </div>
  </div>
</header>

<div class="menu" id="fullmenu" aria-hidden="true">
  <div class="menu__bar wrap wrap--wide">
    <a class="menu__logo" href={r.home}>ArtiMind<span>Art</span></a>
    <button class="menu__close" id="menu-close" aria-label="Close">
      <span>{lang === "es" ? "Cerrar" : "Close"}</span>
      <span class="menu__x" aria-hidden="true"><span></span><span></span></span>
    </button>
  </div>

  <div class="menu__body">
    <div class="menu__left">
      <nav class="menu__nav" aria-label="Primary">
        {nav.map((nLink, i) => (
          <a
            href={r[nLink.key]}
            class={`menu__link ${page === nLink.key ? "is-active" : ""}`}
            data-img={nLink.img}
            style={`transition-delay:${0.12 + i * 0.06}s`}
          >
            <span class="menu__num">{nLink.n}</span>
            <span class="menu__text"><span class="menu__txt-in">{nLink.label}</span></span>
          </a>
        ))}
      </nav>

      <div class="menu__foot">
        <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
        <div class="menu__foot-r">
          <a href={CONTACT.x} target="_blank" rel="noopener">X</a>
          <a href={CONTACT.magnific} target="_blank" rel="noopener">Magnific</a>
          <a href={altHref}>{altLang.toUpperCase()}</a>
        </div>
      </div>
    </div>

    <div class="menu__visual" aria-hidden="true">
      <img id="menu-img" src={nav[0].img} alt="" />
      <span class="menu__visual-cap">ArtiMindArt — Estudio creativo de IA</span>
    </div>
  </div>
</div>

<style>
  /* ---- Header bar ---- */
  .hdr { position: fixed; inset: 0 0 auto 0; z-index: 120; transition: background 0.4s var(--ease), box-shadow 0.4s var(--ease); }
  .hdr.scrolled { background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(14px); box-shadow: 0 1px 0 var(--line); }
  .hdr__inner { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding-block: 1.1rem; }
  .hdr__logo { font-family: var(--font-display); font-size: 1.35rem; letter-spacing: -0.01em; color: var(--ink); transition: color 0.4s; }
  .hdr__logo span { font-style: italic; }
  .hdr__right { display: flex; align-items: center; gap: 1.4rem; }
  .hdr__lang { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.16em; color: var(--ink); transition: color 0.4s, opacity 0.3s; opacity: 0.7; }
  .hdr__lang:hover { opacity: 1; }
  .hdr__menu { display: inline-flex; align-items: center; gap: 0.7rem; background: none; border: 0; cursor: pointer; color: var(--ink); transition: color 0.4s; padding: 0; }
  .hdr__menu-label { font-size: 0.72rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; }
  .hdr__burger { display: inline-flex; flex-direction: column; gap: 5px; width: 26px; }
  .hdr__burger span { height: 1.5px; width: 100%; background: currentColor; display: block; transition: transform 0.3s var(--ease); }

  /* dark variant (over hero video, before scroll) */
  .hdr.is-dark:not(.scrolled) .hdr__logo,
  .hdr.is-dark:not(.scrolled) .hdr__lang,
  .hdr.is-dark:not(.scrolled) .hdr__menu { color: #fff; }

  /* ---- Full-screen menu ---- */
  .menu {
    position: fixed; inset: 0; height: 100svh; z-index: 200;
    background: var(--ink); color: #fff;
    display: flex; flex-direction: column;
    opacity: 0; visibility: hidden; pointer-events: none;
    clip-path: inset(0 0 100% 0);
    transition: clip-path 0.7s var(--ease), opacity 0.4s var(--ease), visibility 0.7s;
  }
  :global(body.menu-open) .menu { opacity: 1; visibility: visible; pointer-events: auto; clip-path: inset(0 0 0% 0); }
  :global(body.menu-open) { overflow: hidden; }

  .menu__bar { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem var(--pad); border-bottom: 1px solid rgba(255,255,255,.12); }
  .menu__logo { font-family: var(--font-display); font-size: 1.35rem; color: #fff; }
  .menu__logo span { font-style: italic; }
  .menu__close { display: inline-flex; align-items: center; gap: 0.7rem; background: none; border: 0; color: #fff; cursor: pointer; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; }
  .menu__x { position: relative; width: 20px; height: 20px; display: inline-block; }
  .menu__x span { position: absolute; top: 50%; left: 0; width: 100%; height: 1px; background: #fff; }
  .menu__x span:first-child { transform: rotate(45deg); }
  .menu__x span:last-child { transform: rotate(-45deg); }

  .menu__body { flex: 1; display: grid; grid-template-columns: 1.15fr 0.85fr; min-height: 0; }
  .menu__left { display: flex; flex-direction: column; justify-content: space-between; padding: clamp(2rem,4vw,3.5rem) clamp(2rem,4vw,4rem); }
  .menu__nav { display: flex; flex-direction: column; gap: 0.1rem; }
  .menu__link {
    display: flex; align-items: baseline; gap: 1.4rem;
    padding: clamp(0.35rem, 0.9vw, 0.7rem) 0;
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.7s var(--ease), transform 0.7s var(--ease), color 0.3s;
  }
  :global(body.menu-open) .menu__link { opacity: 1; transform: none; }
  .menu__num { font-family: var(--font); font-size: 0.72rem; letter-spacing: 0.12em; color: rgba(255,255,255,.4); width: 1.4rem; flex: none; }
  .menu__text { font-family: var(--font-display); font-weight: 300; font-size: clamp(2.6rem, 5.5vw, 5rem); line-height: 1.04; }
  .menu__txt-in { background-image: linear-gradient(#fff,#fff); background-size: 0% 1px; background-position: 0 92%; background-repeat: no-repeat; transition: background-size 0.45s var(--ease); padding-bottom: 0.06em; }
  .menu__nav:hover .menu__link { opacity: 0.35; }
  .menu__nav .menu__link:hover { opacity: 1; }
  .menu__nav .menu__link:hover .menu__txt-in { background-size: 100% 1px; }
  .menu__link.is-active .menu__text { font-style: italic; }

  .menu__foot { display: flex; align-items: center; justify-content: space-between; gap: 1rem; font-size: 0.74rem; letter-spacing: 0.06em; opacity: 0; transition: opacity 0.6s var(--ease) 0.4s; }
  :global(body.menu-open) .menu__foot { opacity: 1; }
  .menu__foot a { color: rgba(255,255,255,.7); transition: color 0.25s; }
  .menu__foot a:hover { color: #fff; }
  .menu__foot-r { display: flex; gap: 1.6rem; text-transform: uppercase; letter-spacing: 0.14em; }

  .menu__visual { position: relative; overflow: hidden; background: #000; }
  .menu__visual img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); transition: opacity 0.45s var(--ease), transform 1.2s var(--ease); transform: scale(1.04); }
  :global(body.menu-open) .menu__visual img { transform: scale(1); }
  .menu__visual-cap { position: absolute; left: 1.4rem; bottom: 1.4rem; font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,.85); }

  @media (max-width: 820px) {
    .menu__body { grid-template-columns: 1fr; }
    .menu__left { justify-content: center; gap: 2.5rem; }
    .menu__visual { display: none; }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const isDark = header?.dataset.dark === "1";
  const onScroll = () => {
    const s = window.scrollY > 20;
    header?.classList.toggle("scrolled", s);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  const body = document.body;
  const openBtn = document.getElementById("menu-open");
  const closeBtn = document.getElementById("menu-close");
  const menu = document.getElementById("fullmenu");

  const open = () => {
    body.classList.add("menu-open");
    menu?.setAttribute("aria-hidden", "false");
    openBtn?.setAttribute("aria-expanded", "true");
  };
  const close = () => {
    body.classList.remove("menu-open");
    menu?.setAttribute("aria-hidden", "true");
    openBtn?.setAttribute("aria-expanded", "false");
  };
  openBtn?.addEventListener("click", open);
  closeBtn?.addEventListener("click", close);
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") close(); });

  // featured image swap on hover
  const img = document.getElementById("menu-img") as HTMLImageElement | null;
  menu?.querySelectorAll(".menu__link").forEach((link) => {
    link.addEventListener("mouseenter", () => {
      const src = (link as HTMLElement).dataset.img;
      if (img && src && img.getAttribute("src") !== src) {
        img.style.opacity = "0";
        setTimeout(() => { img.src = src; img.style.opacity = "1"; }, 180);
      }
    });
  });
</script>
