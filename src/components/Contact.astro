---
import { useTranslations, type Lang, CONTACT } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const waMsg = lang === "es"
  ? "Hola ArtiMindArt, quiero visuales para mi marca:"
  : "Hi ArtiMindArt, I want visuals for my brand:";
const waLink = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent(waMsg)}`;
---

<section class="contact" id="contact">
  <div class="wrap contact__inner">
    <div class="contact__lead">
      <span class="eyebrow" data-reveal>{t("nav.contact")}</span>
      <h1 class="h-xl contact__title" data-reveal style="transition-delay:.05s">{t("contact.title")}</h1>
      <p class="contact__sub" data-reveal style="transition-delay:.1s">{t("contact.body")}</p>
    </div>

    <ul class="contact__list" data-reveal style="transition-delay:.15s">
      <li class="contact__row">
        <span class="contact__k">WhatsApp</span>
        <a class="contact__v" href={waLink} target="_blank" rel="noopener">{t("contact.wa")} <span class="arrow">→</span></a>
      </li>
      <li class="contact__row">
        <span class="contact__k">Asistente</span>
        <button class="contact__v" id="open-chat">{t("contact.chat")} <span class="arrow">→</span></button>
      </li>
      <li class="contact__row">
        <span class="contact__k">X</span>
        <a class="contact__v" href={CONTACT.x} target="_blank" rel="noopener">{CONTACT.xHandle} <span class="arrow">→</span></a>
      </li>
      <li class="contact__row">
        <span class="contact__k">Email</span>
        <a class="contact__v" href={`mailto:${CONTACT.email}`}>{CONTACT.email} <span class="arrow">→</span></a>
      </li>
    </ul>
  </div>
</section>

<style>
  .contact { background: var(--bg); padding-top: clamp(8.5rem, 14vw, 12rem); padding-bottom: clamp(4rem,8vw,7rem); }
  .contact__lead { max-width: 46rem; }
  .contact__title { margin-top: 1.4rem; max-width: 14ch; }
  .contact__sub { margin-top: 1.4rem; max-width: 52ch; color: var(--muted); font-size: clamp(1.05rem,1rem+0.4vw,1.25rem); }
  .contact__list { list-style: none; padding: 0; margin: clamp(3rem,6vw,5rem) 0 0; border-top: 1px solid var(--ink); }
  .contact__row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: clamp(1.3rem,2.5vw,2rem) 0; border-bottom: 1px solid var(--line); }
  .contact__k { font-size: 0.74rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .contact__v { font-family: var(--font-display); font-size: clamp(1.4rem,1rem+1.6vw,2.4rem); display: inline-flex; align-items: center; gap: 0.6em; background: none; border: 0; cursor: pointer; color: var(--ink); transition: color 0.3s; padding: 0; }
  .contact__v .arrow { font-family: var(--font); font-size: 0.6em; transition: transform 0.4s var(--ease); }
  .contact__row:hover .contact__v { color: var(--muted); }
  .contact__row:hover .contact__v .arrow { transform: translateX(6px); }
</style>
