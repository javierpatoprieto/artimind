---
import { useTranslations, routes, type Lang, CONTACT } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const r = routes[lang];
const waMsg = lang === "es"
  ? "Hola ArtiMindArt, quiero visuales para mi marca:"
  : "Hi ArtiMindArt, I want visuals for my brand:";
const waLink = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent(waMsg)}`;
---

<section class="ctab">
  <div class="wrap ctab__inner" data-reveal>
    <span class="eyebrow ctab__eyebrow">{t("nav.contact")}</span>
    <h2 class="h-xl ctab__title">{t("cta.title")}</h2>
    <p class="ctab__sub">{t("cta.sub")}</p>
    <div class="ctab__btns">
      <a class="btn btn--on-dark" href={waLink} target="_blank" rel="noopener">{t("cta.wa")}</a>
      <a class="btn btn--dark ctab__alt" href={r.contact}>{t("nav.contact")} <span class="arrow">→</span></a>
    </div>
  </div>
</section>

<style>
  .ctab { background: var(--ink); color: #fff; padding-block: clamp(5rem, 10vw, 9rem); }
  .ctab__inner { display: grid; place-items: center; text-align: center; gap: 1.4rem; max-width: 50rem; margin-inline: auto; }
  .ctab__eyebrow { color: #fff; }
  .ctab__eyebrow::before { background: #fff; }
  .ctab__title { max-width: 16ch; }
  .ctab__sub { max-width: 48ch; color: rgba(255,255,255,.75); font-size: clamp(1.02rem,1rem+0.3vw,1.2rem); }
  .ctab__btns { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 1rem; }
  .ctab__alt { background: #fff; color: var(--ink); border-color: #fff; }
  .ctab__alt:hover { background: transparent; color: #fff; border-color: rgba(255,255,255,.6); }
</style>
