---
import { useTranslations, type Lang, CONTACT } from "../i18n/ui";
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="mag section">
  <div class="wrap mag__inner" data-reveal>
    <div class="mag__head">
      <span class="eyebrow">{t("magnific.eyebrow")}</span>
      <span class="mag__badge">Magnific · Partner</span>
    </div>
    <h2 class="h-lg mag__title">{t("magnific.title")}</h2>
    <p class="mag__body">{t("magnific.body")}</p>
    <a class="tlink" href={CONTACT.magnific} target="_blank" rel="noopener">
      {t("magnific.cta")} <span class="arrow">→</span>
    </a>
  </div>
</section>

<style>
  .mag { background: var(--bg); padding-top: clamp(2.5rem, 4vw, 3.5rem); }
  .mag__inner { border-top: 1px solid var(--ink); padding-top: clamp(2rem,4vw,3rem); max-width: var(--maxw); }
  .mag__head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: clamp(1.5rem,4vw,2.5rem); }
  .mag__badge { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; border: 1px solid var(--ink); padding: 0.5em 1em; }
  .mag__title { max-width: 18ch; margin-bottom: 1.4rem; }
  .mag__body { max-width: 60ch; color: var(--muted); margin: 0 0 2rem; font-size: clamp(1.02rem,1rem+0.3vw,1.2rem); }
</style>
