---
import { getCollection, getEntry } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import CTABand from "../../../components/CTABand.astro";
import { useTranslations, routes, SITE } from "../../../i18n/ui";

export async function getStaticPaths() {
  const items = await getCollection("work", (e) => e.data.lang === "es");
  return items.map((entry) => ({ params: { slug: entry.data.path }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const lang = "es" as const;
const t = useTranslations(lang);
const r = routes[lang];

const all = (await getCollection("work", (e) => e.data.lang === "es")).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((e) => e.data.path === d.path);
const next = all[(idx + 1) % all.length];

const jsonld = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: d.title,
  about: d.category,
  creator: { "@type": "Organization", name: "ArtiMindArt", url: SITE },
};
---

<Layout lang={lang} page="work" title={`${d.title} — ArtiMindArt`} description={d.excerpt} ogImage={d.cover} jsonld={jsonld}>
  <article class="pr">
    <div class="wrap pr__head">
      <nav class="pr__crumb"><a href={r.work}>{t("work.eyebrow")}</a> <span>/</span> {d.title}</nav>
      <h1 class="h-xl pr__title" data-reveal>{d.title}</h1>
      <dl class="pr__meta" data-reveal style="transition-delay:.05s">
        <div><dt>{t("work.client")}</dt><dd>{d.client}</dd></div>
        <div><dt>{t("work.category")}</dt><dd>{d.category}</dd></div>
        <div><dt>{t("work.year")}</dt><dd>{d.year}</dd></div>
      </dl>
    </div>

    <div class="pr__cover" data-reveal><img src={d.cover} alt={d.title} /></div>

    <div class="wrap pr__body">
      <div class="pr__prose"><Content /></div>
    </div>

    <div class="wrap wrap--wide pr__gallery">
      {d.images.map((src) => <figure data-reveal><img src={src} alt={d.title} loading="lazy" /></figure>)}
    </div>

    <div class="wrap pr__next">
      <a href={`${r.work}${next.data.path}/`}>
        <span class="pr__next-k">{t("work.next")}</span>
        <span class="pr__next-t h-md">{next.data.title} →</span>
      </a>
    </div>
  </article>

  <CTABand lang={lang} />
</Layout>

<style>
  .pr__head { padding-top: clamp(8.5rem,14vw,12rem); padding-bottom: clamp(2rem,4vw,3rem); }
  .pr__crumb { font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.6rem; }
  .pr__crumb a:hover { color: var(--ink); }
  .pr__crumb span { margin: 0 0.4em; }
  .pr__title { max-width: 18ch; }
  .pr__meta { display: flex; flex-wrap: wrap; gap: 2.5rem; margin: 2rem 0 0; }
  .pr__meta dt { font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.4rem; }
  .pr__meta dd { margin: 0; font-family: var(--font-display); font-size: 1.2rem; }
  .pr__cover { aspect-ratio: 16/9; overflow: hidden; margin-bottom: clamp(3rem,6vw,5rem); }
  .pr__cover img { width: 100%; height: 100%; object-fit: cover; }
  .pr__body { display: flex; justify-content: center; }
  .pr__prose { max-width: 60ch; }
  .pr__prose :global(h2) { font-size: 1.6rem; margin: 2.2rem 0 0.8rem; }
  .pr__prose :global(p) { color: var(--ink-2); margin: 0 0 1.2rem; }
  .pr__prose :global(ul) { color: var(--muted); padding-left: 1.1rem; margin: 0 0 1.2rem; }
  .pr__prose :global(li) { margin-bottom: 0.4rem; }
  .pr__gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--line); border: 1px solid var(--line); margin-top: clamp(3rem,6vw,5rem); }
  .pr__gallery figure { margin: 0; overflow: hidden; aspect-ratio: 4/5; background: var(--bg-soft); }
  .pr__gallery img { width: 100%; height: 100%; object-fit: cover; transition: transform 1s var(--ease); }
  .pr__gallery figure:hover img { transform: scale(1.04); }
  .pr__next { padding-block: clamp(3rem,6vw,5rem); border-top: 1px solid var(--ink); margin-top: clamp(3rem,6vw,5rem); }
  .pr__next-k { display: block; font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.6rem; }
  .pr__next-t { transition: opacity 0.3s; }
  .pr__next a:hover .pr__next-t { opacity: 0.6; }
  @media (max-width: 700px) { .pr__gallery { grid-template-columns: 1fr; } }
</style>
