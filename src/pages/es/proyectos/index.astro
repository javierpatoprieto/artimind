---
import Layout from "../../../layouts/Layout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import WorkGrid from "../../../components/WorkGrid.astro";
import CTABand from "../../../components/CTABand.astro";
import { useTranslations } from "../../../i18n/ui";
const lang = "es" as const;
const t = useTranslations(lang);
---

<Layout
  lang={lang}
  page="work"
  title="Proyectos — ArtiMindArt | Casos de moda y producto con IA"
  description="Una selección de proyectos de moda y producto creados con IA: campañas, editoriales y catálogos para marcas."
>
  <PageHeader kicker={t("work.eyebrow")} title={t("work.title")} sub={t("work.sub")} />
  <WorkGrid lang={lang} heading={false} />
  <CTABand lang={lang} />
</Layout>
