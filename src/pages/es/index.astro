---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import Proof from "../../components/Proof.astro";
import StatsBand from "../../components/StatsBand.astro";
import ServicesTeaser from "../../components/ServicesTeaser.astro";
import WorkGrid from "../../components/WorkGrid.astro";
import FeaturedPosts from "../../components/FeaturedPosts.astro";
import Magnific from "../../components/Magnific.astro";
import XFeed from "../../components/XFeed.astro";
import CTABand from "../../components/CTABand.astro";
const lang = "es" as const;
---

<Layout
  lang={lang}
  page="home"
  title="ArtiMindArt — Imágenes y vídeos de IA que venden | Moda y producto"
  description="Estudio creativo de IA. Convierto cualquier producto en imágenes y vídeos con calidad de gran producción. Especialista en moda y producto. Partner oficial de Magnific."
>
  <Hero lang={lang} />
  <Proof lang={lang} />
  <ServicesTeaser lang={lang} />
  <StatsBand lang={lang} />
  <WorkGrid lang={lang} limit={3} more />
  <Magnific lang={lang} />
  <FeaturedPosts lang={lang} />
  <XFeed lang={lang} />
  <CTABand lang={lang} />
</Layout>
