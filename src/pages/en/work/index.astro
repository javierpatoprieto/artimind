---
import Layout from "../../../layouts/Layout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import WorkGrid from "../../../components/WorkGrid.astro";
import CTABand from "../../../components/CTABand.astro";
import { useTranslations } from "../../../i18n/ui";
const lang = "en" as const;
const t = useTranslations(lang);
---

<Layout
  lang={lang}
  page="work"
  title="Work — ArtiMindArt | AI fashion and product cases"
  description="A selection of fashion and product projects created with AI: campaigns, editorials and catalogs for brands."
>
  <PageHeader kicker={t("work.eyebrow")} title={t("work.title")} sub={t("work.sub")} />
  <WorkGrid lang={lang} heading={false} />
  <CTABand lang={lang} />
</Layout>
