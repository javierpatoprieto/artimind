---
import Layout from "../../layouts/Layout.astro";
import CTABand from "../../components/CTABand.astro";
import { services } from "../../data/services";
import { useTranslations, routes, SITE } from "../../i18n/ui";

export function getStaticPaths() {
  return services.en.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}
const { service } = Astro.props;
const lang = "en" as const;
const t = useTranslations(lang);
const r = routes[lang];
const jsonld = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.title,
  description: service.metaDesc,
  provider: { "@type": "Organization", name: "ArtiMindArt", url: SITE },
  areaServed: "Worldwide",
};
---

<Layout lang={lang} page="services" title={service.metaTitle} description={service.metaDesc} ogImage={service.images[0]} jsonld={jsonld}>
  <section class="sd">
    <div class="wrap sd__head">
      <nav class="sd__crumb"><a href={r.services}>{t("services.eyebrow")}</a> <span>/</span> {service.title}</nav>
      <h1 class="h-xl sd__title" data-reveal>{service.title}</h1>
      <p class="sd__tag" data-reveal style="transition-delay:.05s">{service.tagline}</p>
    </div>
    <hr class="rule" />
  </section>

  <section class="section sd__body">
    <div class="wrap sd__grid">
      <div class="sd__intro" data-reveal>
        <p class="lead">{service.intro}</p>
        <a class="btn btn--dark sd__cta" href={r.contact}>{t("hero.cta")} <span class="arrow">→</span></a>
      </div>
      <div class="sd__includes" data-reveal style="transition-delay:.08s">
        <h2 class="sd__inc-h">What's included</h2>
        <ul>
          {service.includes.map((it) => <li>{it}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="sd__gallery">
    <div class="wrap wrap--wide sd__imgs">
      {service.images.map((src) => <figure data-reveal><img src={src} alt={service.title} loading="lazy" /></figure>)}
    </div>
  </section>

  <CTABand lang={lang} />
</Layout>

<style>
  .sd__head { padding-top: clamp(8.5rem, 14vw, 12rem); }
  .sd__crumb { font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 1.6rem; }
  .sd__crumb a { color: var(--muted); } .sd__crumb a:hover { color: var(--ink); }
  .sd__crumb span { margin: 0 0.4em; }
  .sd__title { max-width: 16ch; }
  .sd__tag { margin-top: 1.2rem; font-size: clamp(1.1rem,1rem+0.5vw,1.4rem); color: var(--muted); max-width: 44ch; }
  .sd .rule { margin-top: clamp(2.5rem,5vw,4rem); }
  .sd__grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(2rem,5vw,5rem); }
  .sd__cta { margin-top: 2rem; }
  .sd__inc-h { font-family: var(--font); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 1.4rem; }
  .sd__includes ul { list-style: none; padding: 0; margin: 0; }
  .sd__includes li { padding: 0.9rem 0; border-top: 1px solid var(--line); font-size: 1.02rem; }
  .sd__includes li:last-child { border-bottom: 1px solid var(--line); }
  .sd__gallery { padding-bottom: clamp(4rem,8vw,7rem); }
  .sd__imgs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .sd__imgs figure { margin: 0; aspect-ratio: 4/5; overflow: hidden; background: var(--bg-soft); filter: grayscale(1); transition: filter 0.6s var(--ease); }
  .sd__imgs figure:hover { filter: grayscale(0); }
  .sd__imgs img { width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 820px) { .sd__grid { grid-template-columns: 1fr; } .sd__imgs { grid-template-columns: 1fr 1fr; } }
</style>
